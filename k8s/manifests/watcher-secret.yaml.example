# IMPORTANT: replace the GEMINI_API_KEY value below with your real key
# before applying this file. Do not commit this file with a real key filled in --
# see the note in the deployment guide about keeping a local-only copy.
apiVersion: v1
kind: Secret
metadata:
  name: watcher-secret
type: Opaque
stringData:
  DATABASE_URL: "postgresql://watcher:watcherpass@postgres:5432/watcherdb"
  GEMINI_API_KEY: "REPLACE_WITH_YOUR_REAL_GEMINI_KEY"
  REMEDIATION_DRY_RUN: "true"
